# Contributor: Tommy Buado <tommy@thinkpad.local>
# Maintainer: Tommy Buado <tommy@thinkpad.local>
pkgname=st
pkgver=0.9
pkgrel=0
pkgdesc="A simple terminal emulator for X"
url="https://st.suckless.org"
arch="all"
license="MIT"
depends="ncurses-terminfo-base"
makedepends="fontconfig-dev freetype-dev libx11-dev libxext-dev libxft-dev"
subpackages="$pkgname-doc $pkgname-dbg"
options="!check"
source="https://dl.suckless.org/st/st-$pkgver.tar.gz
	st.desktop
	config.h
	patches/0001-Custom-rendering-of-lines-blocks-braille-characters-.patch
	patches/0002-Allow-st-to-resize-to-any-pixel-size-make-the-inner-.patch
	patches/0003-Hide-cursor-whenever-a-key-is-pressed-and-show-it-ba.patch"

provides="st-virtual"
provider_priority=100

prepare() {
	default_prepare
	sed -i "/tic/d" Makefile
	cp -pr "$srcdir"/config.h config.h
}

build() {
	make
}

package() {
	make PREFIX=/usr DESTDIR="$pkgdir" install
	install -Dm644 "$srcdir"/st.desktop \
		-t "$pkgdir"/usr/share/applications/
}

