# Contributor: Tommy Buado <tommy@thinkpad.local>
# Maintainer: Tommy Buado <tommy@thinkpad.local>
pkgname=dwm
pkgver=6.4
pkgrel=1
pkgdesc="A dynamic window manager for X"
url="https://dwm.suckless.org"
arch="all"
license="MIT"
depends="dmenu-virtual st-virtual"
makedepends="libxft-dev libx11-dev libxinerama-dev"
subpackages="$pkgname-doc"
options="!check"
source="https://dl.suckless.org/dwm/dwm-$pkgver.tar.gz
	dwm.desktop
	config.h
	patches/0001-Make-dwm-run-autostart-scripts-before-entering-the-h.patch
	patches/0002-Allow-colors-and-rectangle-drawing-in-dwm.patch
	patches/0003-Switch-focus-only-by-mouse-click-and-not-sloppy.patch
	patches/0004-Activate-the-window-as-response-to-client-request-_N.patch
	patches/0005-Add-a-rule-option-to-switch-to-the-configured-tag-wh.patch
	patches/0006-Keep-layout-mwfact-barpos-and-nmaster-per-tag.patch
	patches/0007-Always-display-the-monocle-symbol-if-the-monocle-lay.patch
	patches/0008-Add-bar-spacing-remove-title-and-center-all-floating.patch
	patches/0009-Press-MODKEY-s-default-to-make-a-client-sticky.patch
	patches/0010-Add-gaps-between-client-windows-for-tile-layout-only.patch
	patches/0011-Add-whitespace-in-default-status-VERSION-of-dwm.patch"

provides="dwm-virtual"
provider_priority=100

prepare() {
	default_prepare
	sed -i -e "/CFLAGS/{s/-Os//;s/=/+=/}" \
		-e "/LDFLAGS/{s/=/+=/}" config.mk
	cp -pr "$srcdir"/config.h config.h
}

build() {
	make X11INC=/usr/include/X11 \
		X11LIB=/usr/lib/X11 \
		FREETYPEINC=/usr/include/freetype2
}

package() {
	make PREFIX=/usr DESTDIR="$pkgdir" install
	install -Dm644 "$srcdir"/dwm.desktop \
		-t "$pkgdir"/usr/share/xsessions/
}

