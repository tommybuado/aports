pkgname=mono-gtk-theme
pkgver=1.3
pkgrel=0
pkgdesc="A mono gtk theme for GNOME"
url="https://github.com/witalihirsch/Mono-gtk-theme"
arch="noarch"
license="GPL-3.0-or-later"
options="!check"
source="$pkgname-$pkgver.tar.gz LICENSE"

package() {
	mkdir -p "$pkgdir"/usr/share/themes/
	cp -pr "$srcdir"/Mono "$pkgdir"/usr/share/themes/

	install -Dm644 "$srcdir"/LICENSE \
		-t "$pkgdir"/usr/share/licenses/$pkgname/
}

