# Maintainer: Tommy Buado <tommy@thinkpad.local>
pkgname=mono-gtk-theme
pkgver=1.3
pkgrel=0
pkgdesc="A mono theme for GNOME"
url="https://github.com/witalihirsch/Mono-gtk-theme"
arch="noarch"
license="GPL-3.0"
options="!check"
source="$pkgname-$pkgver.tar.gz LICENSE"

package() {
	default_prepare
	sed -i 's/#1b82b3/#5f5fee/g' "$srcdir"/Mono/**/*.css

	mkdir -p "$pkgdir"/usr/share/themes/Mono
	cp -pr "$srcdir"/Mono/* "$pkgdir"/usr/share/themes/Mono/

	install -Dm644 "$srcdir"/LICENSE \
		-t "$pkgdir"/usr/share/licenses/$pkgname/
}

sha512sums="
