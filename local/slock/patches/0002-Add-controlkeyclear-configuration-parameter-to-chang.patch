From fb6f3790eb853205cf4297b501eb5951c8f35d77 Mon Sep 17 00:00:00 2001
From: Tommy Buado <tommy@thinkpad.local>
Date: Fri, 14 Jul 2023 03:18:55 +0800
Subject: [PATCH 2/2] Add controlkeyclear configuration parameter to change
 failure color if control key is pressed

---
 config.def.h | 3 +++
 slock.c      | 5 +++--
 2 files changed, 6 insertions(+), 2 deletions(-)

diff --git a/config.def.h b/config.def.h
index d01bd38..d1a42f6 100644
--- a/config.def.h
+++ b/config.def.h
@@ -13,3 +13,6 @@ static const int failonclear = 1;
 
 /* time in seconds before the monitor shuts down */
 static const int monitortime = 5;
+
+/* allow control key to trigger fail on clear */
+static const int controlkeyclear = 0;
diff --git a/slock.c b/slock.c
index c934f28..3db79c8 100644
--- a/slock.c
+++ b/slock.c
@@ -181,8 +181,9 @@ readpw(Display *dpy, struct xrandr *rr, struct lock **locks, int nscreens,
 					passwd[--len] = '\0';
 				break;
 			default:
-				if (num && !iscntrl((int)buf[0]) &&
-				    (len + num < sizeof(passwd))) {
+				if (controlkeyclear && iscntrl((int)buf[0]))
+					continue;
+				if (num && (len + num < sizeof(passwd))) {
 					memcpy(passwd + len, buf, num);
 					len += num;
 				}
-- 
2.40.1

