# Contributor: Tommy Buado <tommy@thinkpad.local>
# Maintainer: Tommy Buado <tommy@thinkpad.local>
pkgname=slock
pkgver=1.5
pkgrel=0
pkgdesc="A simple screen locker for X"
url="https://tools.suckless.org/slock/"
arch="all"
license="MIT"
makedepends="libxext-dev libxrandr-dev linux-headers"
subpackages="$pkgname-doc"
options="suid !check"
source="https://dl.suckless.org/tools/slock-$pkgver.tar.gz
	config.h
	patches/0001-Interact-with-the-Display-Power-Management-Signaling.patch
	patches/0002-Add-controlkeyclear-configuration-parameter-to-chang.patch"

prepare() {
	default_prepare
	sed -i -e "/CFLAGS/{s/-Os//;s/=/+=/}" \
		-e "/LDFLAGS/{s/-s//;s/=/+=/}" config.mk
	cp -pr "$srcdir"/config.h config.h
}

build() {
	make X11INC=/usr/include/X11 \
		X11LIB=/usr/lib/X11
}

package() {
	make PREFIX=/usr DESTDIR="$pkgdir" install
}

