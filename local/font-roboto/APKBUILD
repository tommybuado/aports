# Maintainer: Tommy Buado <tommy@thinkpad.local>
pkgname=font-roboto
pkgver=20240113
pkgrel=0
pkgdesc="The Google Roboto Font Family"
url="https://fonts.google.com/"
arch="noarch"
license="Apache-2.0"
options="!check"
source="$pkgname-v$pkgver.tar.gz 45-roboto.conf LICENSE"

package() {
	default_prepare
	install -Dm644 "$srcdir"/Roboto/*.ttf \
		-t "$pkgdir"/usr/share/fonts/roboto/
	install -Dm644 "$srcdir"/45-roboto.conf \
		-t "$pkgdir"/etc/fonts/conf.avail/
	install -Dm644 "$srcdir"/LICENSE \
		-t "$pkgdir"/usr/share/licenses/$pkgname/

	cd "$pkgdir"

	mkdir -p etc/fonts/conf.d/
	ln -s ../conf.avail/45-roboto.conf etc/fonts/conf.d/
}

