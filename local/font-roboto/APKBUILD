# Maintainer: Tommy Buado <tommy@thinkpad.local>
pkgname=font-roboto
pkgver=3.005
pkgrel=0
pkgdesc="Google Roboto Font"
url="https://fonts.google.com/specimen/Roboto"
arch="noarch"
license="Apache-2.0"
options="!check"
source="$pkgname-$pkgver.tar.gz 45-roboto.conf LICENSE"

package() {
	install -Dm644 "$srcdir"/Roboto/*.ttf -t "$pkgdir"/usr/share/fonts/roboto/
	install -Dm644 "$srcdir"/LICENSE -t "$pkgdir"/usr/share/licenses/$pkgname/
	install -Dm644 "$srcdir"/45-roboto.conf -t "$pkgdir"/etc/fonts/conf.avail/

	mkdir -p "$pkgdir"/etc/fonts/conf.d
	ln -s "$pkgdir"/etc/fonts/conf.avail/45-roboto.conf "$pkgdir"/etc/fonts/conf.d/
}

